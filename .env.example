# ─────────────────────────────────────────────────────────────
# Jetlisans — ortam değişkenleri örneği
# Bu dosyayı `.env` olarak kopyalayıp değerleri doldurun.
# .env ASLA commit edilmez (.gitignore'da).
# ─────────────────────────────────────────────────────────────

# Genel
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=jetlisans
POSTGRES_PASSWORD=degistir_beni_guclu_parola
POSTGRES_DB=jetlisans
# Uygulama bağlantısı (compose içinde host = "postgres")
DATABASE_URL=postgres://jetlisans:degistir_beni_guclu_parola@postgres:5432/jetlisans
# Lokal (Docker dışı) çalıştırma için:
# DATABASE_URL=postgres://jetlisans:degistir_beni_guclu_parola@localhost:5432/jetlisans

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# Lokal: redis://localhost:6379

# ── API ─────────────────────────────────────────────────────
API_PORT=3001
# Payload şifreleme master anahtarı (AES-256-GCM envelope).
# 32 byte base64. Üretim: `openssl rand -base64 32`
# ÜRETİMDE bu değer DB yedeğinden AYRI secret store'da tutulur.
MASTER_KEY=

# Admin uçları (site/ürün/stok yönetimi) için yönetici token'ı.
# Üret: openssl rand -hex 24
ADMIN_TOKEN=

# İlk admin bootstrap (§8) — admin_users tablosu BOŞSA açılışta bir "owner" admin
# oluşturulur. Sonraki adminler panelden eklenir. İkisi de gerekli (opsiyonel özellik).
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=Yönetici
ADMIN_SEED_USERNAME=

# ── Admin (Next.js) ─────────────────────────────────────────
ADMIN_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
# Oturum imza sırrı (§8). SET EDİLİRSE çoklu-admin auth AKTİF olur → /login zorunlu,
# kimlik admin_users'a karşı doğrulanır. BOŞ = auth kapalı (panel herkese açık!).
# Üret: openssl rand -hex 32. İlk admin için ayrıca ADMIN_SEED_* (yukarıda) verin.
SESSION_SECRET=

# ── Mail / SMTP (teslimat bildirimleri) ─────────────────────
# Dev: Mailpit (compose'ta SMTP_HOST=mailpit, SMTP_PORT=1025, TLS'siz) — override gerekmez.
# ÜRETİM: gerçek SMTP relay bilgilerini buradan verin.
SMTP_HOST=mailpit
SMTP_PORT=1025
# Üretimde TLS için "true" (587/465). Dev Mailpit TLS'siz olduğu için "false".
SMTP_SECURE=false
# Gönderen adresi (görünen ad + adres). Üretimde kendi domaininizi kullanın.
MAIL_FROM=Jetlisans <teslimat@jetlisans.local>
# NOT: SMTP kimlik doğrulaması (SMTP_USER/SMTP_PASS) henüz nodemailer transport'una
# bağlı DEĞİL (mail.processor.ts yalnız host/port/secure kullanır). Kimlik isteyen bir
# relay kullanacaksanız önce transport'a `auth: { user, pass }` eklenmeli.

# ── Telegram bildirim (opsiyonel, env-gated) ────────────────
# Düşük stok / kritik olay bildirimleri için (§12). İKİSİ de boşsa gönderim no-op
# (özellik kapalı, panel içi bildirim akışı yine çalışır). BotFather'dan token alın,
# chat_id'yi @userinfobot veya getUpdates ile öğrenin.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Caddy / domain ──────────────────────────────────────────
# Üretimde gerçek domainler; lokalde otomatik iç TLS.
# ÖNEMLİ: iki domain ASLA aynı olamaz — Caddy "ambiguous site definition" verir.
# Lokalde admin=localhost, api=api.localhost (*.localhost loopback'e çözülür).
ADMIN_DOMAIN=localhost
API_DOMAIN=api.localhost

# ── Gözlem (opsiyonel, Faz 0'da boş bırakılabilir) ──────────
SENTRY_DSN=
