    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.1",
    "@jetlisans/shared": "workspace:*",
    "@nestjs/bullmq": "^11.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.0.1",
    "bullmq": "^5.34.6",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.2",
    "nodemailer": "^6.9.16",
    "nestjs-pino": "^4.2.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
